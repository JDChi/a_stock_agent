APP_NAME=a-stock-agent
ENVIRONMENT=development

DATABASE_PATH=data/a_stock_agent.sqlite3
BOOKS_DIR=books
MODELS_DIR=data/models

EMBEDDING_MODEL=BAAI/bge-base-zh-v1.5
EMBEDDING_DIMENSIONS=768

# MiniMax Anthropic-compatible defaults.
LLM_PROVIDER=anthropic
LLM_MODEL=MiniMax-M2.7-highspeed
LLM_BASE_URL=https://api.minimaxi.com/anthropic
LLM_API_KEY=
LLM_AUTH_TOKEN=

# Compatibility with the earlier ADK Go demo is also supported:
# ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_MODEL=MiniMax-M2.7-highspeed

ENABLE_LIVE_AKSHARE=true
ENABLE_ADK_WEB_UI=false

# AKShare network control. Set AKSHARE_PROXY_URL to a real HTTP/SOCKS proxy
# when public data sources limit the current IP.
AKSHARE_PROXY_URL=
AKSHARE_DISABLE_SYSTEM_PROXY=true
